{% extends 'base-page.htt' %}

{% block content %}
<div class="results-page">
	<h1>Positions</h1>

	{{ filterHtml | raw }}

	{% if positions|length > 0 %}
		{{ tableHtml | raw }}
		{{ paginationHtml | raw }}
	{% else %}
		<div class="no-results">No positions match your filters.</div>
	{% endif %}
</div>
{% endblock %}
